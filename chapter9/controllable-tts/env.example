# OpenAI API Key（有效，用于调用 TTS）
OPENAI_API_KEY=your_openai_api_key_here

# 可选：覆盖首选 TTS 模型。默认 gpt-4o-mini-tts（支持 instructions 风格控制），
# 不可用时代码会自动兜底到 tts-1。
# TTS_MODEL=gpt-4o-mini-tts

# 说明：书中实验 9-5 使用 Fish Audio（无可用 key），本项目改用 OpenAI TTS 演示
# 相同的「控制标记 -> 风格化语音」思路。请勿使用 OPENROUTER / ANTHROPIC /
# DEEPSEEK / SILICONFLOW（这些在本环境失效）。
